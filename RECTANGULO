class Rectangulo(FiguraGeometrica):
    def __init__(self, ancho, alto):
        super().__init__(ancho, alto)

    def area(self):
        return self.ancho * self.alto

    def perimetro(self):
        return (self.ancho * 2) + (self.alto * 2)

    def __str__(self):
        return f"Rectángulo [Ancho: {self.ancho}, Alto: {self.alto}]"
